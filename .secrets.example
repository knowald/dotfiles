# Secrets and API tokens (not tracked in git)
# Copy to ~/.secrets and customize
# chmod 600 ~/.secrets

# ===================
# AI / LLM
# ===================
# export ANTHROPIC_API_KEY="sk-ant-..."
# export OPENAI_API_KEY="sk-..."

# ===================
# Git Platforms
# ===================
# GitLab personal access token
# export GITLAB_TOKEN="glpat-..."
# export GITLAB_ACCESS_TOKEN=$GITLAB_TOKEN

# GitHub token (for API access beyond gh auth)
# export GITHUB_TOKEN="ghp_..."

# ===================
# Cloud Providers
# ===================
# AWS (if not using ~/.aws/credentials)
# export AWS_ACCESS_KEY_ID="AKIA..."
# export AWS_SECRET_ACCESS_KEY="..."

# DigitalOcean
# export DO_API_TOKEN="dop_..."

# Hetzner
# export HCLOUD_TOKEN="..."

# ===================
# Infrastructure
# ===================
# Terraform Cloud
# export TF_TOKEN_app_terraform_io="..."

# Ansible Vault
# export ANSIBLE_VAULT_PASSWORD="..."

# ===================
# Databases
# ===================
# PostgreSQL default connection
# export PGHOST="localhost"
# export PGUSER="postgres"
# export PGPASSWORD="..."

# Redis
# export REDIS_URL="redis://localhost:6379"

# ===================
# Services
# ===================
# Sentry
# export SENTRY_DSN="https://...@sentry.io/..."

# Datadog
# export DD_API_KEY="..."

# SendGrid / Email
# export SENDGRID_API_KEY="SG...."

# Twilio
# export TWILIO_ACCOUNT_SID="AC..."
# export TWILIO_AUTH_TOKEN="..."

# ===================
# Password Aliases
# ===================
# Quick password copy (use with caution)
# alias pw-vpn="echo -n 'your-vpn-password' | pbcopy"
# alias pw-server="security find-generic-password -s 'server-name' -w | pbcopy"
