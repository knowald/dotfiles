# SSH Configuration
# Machine-specific hosts go in ~/.ssh/config.local (not tracked)

# Include local host definitions
Include config.local

# GitLab
Host gitlab.com
    IdentitiesOnly yes
    # IdentityFile configured in config.local

# Default settings for all hosts
Host *
    AddKeysToAgent yes
    # IdentityFile configured in config.local
    # macOS only: UseKeychain yes
    IgnoreUnknown UseKeychain
    UseKeychain yes
    PermitLocalCommand yes
    LocalCommand if [ -n "$TMUX_PANE" ]; then tmux set -p -t "$TMUX_PANE" @is_ssh 1 && tmux set -p -t "$TMUX_PANE" @ssh_target "%r@%h"; fi
