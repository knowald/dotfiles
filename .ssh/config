# SSH Configuration
# Machine-specific hosts go in ~/.ssh/config.local (not tracked)

# Include local host definitions
Include config.local

# GitHub
Host github.com
    HostName github.com
    IdentitiesOnly yes
    # User and IdentityFile configured in config.local

# GitLab
Host gitlab.com
    IdentitiesOnly yes
    # IdentityFile configured in config.local

# Default settings for all hosts
Host *
    AddKeysToAgent yes
    IdentitiesOnly yes
    # macOS only: UseKeychain yes
    IgnoreUnknown UseKeychain
    UseKeychain yes
