# Machine-specific SSH hosts (not tracked in git)
# Copy to ~/.ssh/config.local and customize

# ===================
# Git Services
# ===================
# GitHub - personal account
Match host github.com
    User yourusername
    IdentityFile ~/.ssh/id_ed25519

# GitHub - work account (if using multiple)
# Host github.com-work
#     HostName github.com
#     User workusername
#     IdentityFile ~/.ssh/work_key

# GitLab
# Match host gitlab.com
#     IdentityFile ~/.ssh/id_ed25519

# Self-hosted Git
# Host git.company.com
#     IdentityFile ~/.ssh/work_key
#     User git

# ===================
# Project Servers
# ===================
# Production
# Host prod
#     HostName 1.2.3.4
#     User deploy
#     IdentityFile ~/.ssh/deploy_key

# Staging
# Host staging
#     HostName 5.6.7.8
#     User deploy
#     IdentityFile ~/.ssh/deploy_key

# Database server (with port forward)
# Host db-prod
#     HostName 10.0.1.5
#     User admin
#     LocalForward 5433 localhost:5432

# ===================
# Jump Hosts / Bastions
# ===================
# Bastion host
# Host bastion
#     HostName bastion.example.com
#     User admin
#     IdentityFile ~/.ssh/bastion_key

# Server behind bastion
# Host internal-server
#     HostName 10.0.0.5
#     User admin
#     ProxyJump bastion

# ===================
# Cloud VMs
# ===================
# AWS EC2
# Host aws-web
#     HostName ec2-xx-xx-xx-xx.compute-1.amazonaws.com
#     User ec2-user
#     IdentityFile ~/.ssh/aws-key.pem

# Hetzner
# Host hetzner-1
#     HostName 1.2.3.4
#     User root

# DigitalOcean
# Host droplet
#     HostName 5.6.7.8
#     User root

# ===================
# Raspberry Pi / Home
# ===================
# Home server
# Host homelab
#     HostName 192.168.1.100
#     User pi

# NAS
# Host nas
#     HostName 192.168.1.50
#     User admin
